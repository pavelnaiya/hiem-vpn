{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hiem VPN",
  "version": "0.1.0",
  "identifier": "com.pavelnaiya.hiem",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Hiem VPN",
        "width": 800,
        "height": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "externalBin": [
      "bin/python-backend",
      "bin/tor",
      "bin/privoxy"
    ],
    "resources": [],
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [
        "bin/dylibs/libpcre2-8.0.dylib",
        "bin/dylibs/libssl.3.dylib",
        "bin/dylibs/libscrypt.0.dylib",
        "bin/dylibs/libcrypto.3.dylib",
        "bin/dylibs/libevent-2.1.7.dylib",
        "bin/dylibs/libpcre2-posix.3.dylib"
      ]
    }
  }
}